[
  {
    "event": "PostToolUse",
    "matcher": "Bash",
    "hooks": [
      {
        "type": "command",
        "command": "bun .claude/hooks/context.ts tool-output-trim",
        "timeout": 5
      }
    ]
  },
  {
    "event": "PreCompact",
    "matcher": "",
    "hooks": [
      {
        "type": "command",
        "command": "bun .claude/hooks/context.ts precompact-dump",
        "timeout": 5
      }
    ]
  }
]
